---
pagination:
  data: collections
  size: 1
  alias: tag
  filter: ["all", "post", "posts", "tagList"]
permalink: /tag/{{ tag | slugify }}/index.html
layout: false
---
<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ tag }} — Blog | BTC Consulting</title>
  <meta name="description" content="Artykuły na temat: {{ tag }}. Blog BTC Consulting.">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800&family=Barlow:wght@400;500;600;700&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/v5/design-system.css">

  <style>
    .blog-card {
      background: var(--c-surface-w); padding: 2.5rem 2rem;
      display: flex; flex-direction: column; gap: 1rem;
      text-decoration: none; color: inherit; transition: background 0.15s;
    }
    .blog-card:hover { background: var(--c-white); }
    .blog-card__date {
      font-family: var(--f-display); font-size: 11px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.1em; color: var(--c-gray);
    }
    .blog-card__title {
      font-family: var(--f-display); font-weight: 800;
      font-size: clamp(1rem, 1.5vw, 1.25rem); text-transform: uppercase;
      letter-spacing: -0.01em; color: var(--c-black); line-height: 1.3;
    }
    .blog-card__desc { font-size: 0.875rem; line-height: 1.7; color: var(--c-gray-d); }
  </style>
</head>
<body>

<script src="/v5/partials/header.js"></script>

<section class="hero" aria-label="Tag: {{ tag }}">
  <div class="hero__content">
    <p class="t-label">Blog · Tag</p>
    <h1 class="t-display reveal">{{ tag }}</h1>
    <p class="t-lead reveal" style="color:var(--c-gray-d)">
      <a href="{{ site.blogPath }}/" style="color:var(--c-accent)">← Wszystkie artykuły</a>
    </p>
  </div>
</section>

<section class="section" aria-label="Artykuły">
  <div class="container">
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:3px">
      {% for post in collections[tag] | reverse %}
      <a class="blog-card reveal" href="{{ site.blogPath }}{{ post.url }}">
        <span class="blog-card__date">{{ post.date | readableDate }}</span>
        <span class="blog-card__title">{{ post.data.title }}</span>
        <span class="blog-card__desc">{{ post.data.description }}</span>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

<script src="/v5/translations/pl.js"></script>
<script src="/v5/i18n.js"></script>
<script src="/v5/partials/footer.js?v=3"></script>
<script src="/v5/reveal.js"></script>

</body>
</html>
